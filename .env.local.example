# .env.local
# Copy this file to .env.local — NEVER commit .env.local to git

# ── AIRTABLE ────────────────────────────────────────────────────
# Get from: airtable.com → Account → API → Personal access token
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Get from: airtable.com → your base → Help → API documentation → Base ID
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── OPTIONAL ────────────────────────────────────────────────────
# If you add analytics later (e.g. Plausible, Vercel Analytics)
# NEXT_PUBLIC_ANALYTICS_ID=
